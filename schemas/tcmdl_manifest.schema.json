{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TCMDL Manifest",
  "type": "object",
  "required": [
    "format",
    "format_version",
    "architecture",
    "model",
    "sections"
  ],
  "properties": {
    "format": {
      "const": "TCMDL"
    },
    "format_version": {
      "type": "string"
    },
    "architecture": {
      "type": "string"
    },
    "model": {
      "type": "object"
    },
    "tokenizer": {
      "type": "object"
    },
    "quantization": {
      "type": "object"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
