{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TinyCore Training Run",
  "type": "object",
  "required": [
    "run_id",
    "model_config",
    "dataset",
    "optimizer",
    "training"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "model_config": {
      "type": "string"
    },
    "dataset": {
      "type": "string"
    },
    "optimizer": {
      "type": "object",
      "required": [
        "name",
        "lr"
      ],
      "properties": {
        "name": {
          "enum": [
            "adamw",
            "sgd"
          ]
        },
        "lr": {
          "type": "number"
        },
        "weight_decay": {
          "type": "number"
        }
      }
    },
    "training": {
      "type": "object",
      "properties": {
        "batch_size": {
          "type": "integer"
        },
        "seq_len": {
          "type": "integer"
        },
        "max_steps": {
          "type": "integer"
        },
        "eval_interval": {
          "type": "integer"
        },
        "grad_clip": {
          "type": "number"
        }
      }
    }
  },
  "additionalProperties": true
}
